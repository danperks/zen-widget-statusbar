[
  {
    "type": "text",
    "label": "Widget Statusbar",
    "margin": "20px 0 8px 0",
    "size": "20px"
  },
  {
    "type": "text",
    "label": "Lower order numbers appear first within the chosen left, centre, or right area. Changes update the statusbar live once the script is running.",
    "margin": "0 0 18px 0"
  },
  {
    "type": "separator",
    "label": "Website Domain",
    "margin": "16px 0 12px 0"
  },
  {
    "type": "checkbox",
    "property": "zen.widgetStatusbar.widgets.domain.enabled",
    "label": "Show website domain",
    "defaultValue": true,
    "margin": "12px 0"
  },
  {
    "type": "dropdown",
    "property": "zen.widgetStatusbar.widgets.domain.side",
    "label": "Side",
    "defaultValue": "right",
    "placeholder": false,
    "options": [
      { "label": "Left", "value": "left" },
      { "label": "Centre", "value": "center" },
      { "label": "Right", "value": "right" }
    ]
  },
  {
    "type": "string",
    "property": "zen.widgetStatusbar.widgets.domain.order",
    "label": "Order",
    "value": "number",
    "defaultValue": 10,
    "placeholder": "10"
  },
  {
    "type": "separator",
    "label": "Clock",
    "margin": "16px 0 12px 0"
  },
  {
    "type": "checkbox",
    "property": "zen.widgetStatusbar.widgets.clock.enabled",
    "label": "Show clock",
    "defaultValue": true,
    "margin": "12px 0"
  },
  {
    "type": "dropdown",
    "property": "zen.widgetStatusbar.widgets.clock.side",
    "label": "Side",
    "defaultValue": "left",
    "placeholder": false,
    "options": [
      { "label": "Left", "value": "left" },
      { "label": "Centre", "value": "center" },
      { "label": "Right", "value": "right" }
    ]
  },
  {
    "type": "string",
    "property": "zen.widgetStatusbar.widgets.clock.order",
    "label": "Order",
    "value": "number",
    "defaultValue": 10,
    "placeholder": "10"
  },
  {
    "type": "dropdown",
    "property": "zen.widgetStatusbar.clock.format",
    "label": "Clock format",
    "defaultValue": "locale",
    "placeholder": false,
    "options": [
      { "label": "Locale Default", "value": "locale" },
      { "label": "12 Hour", "value": "12h" },
      { "label": "24 Hour", "value": "24h" }
